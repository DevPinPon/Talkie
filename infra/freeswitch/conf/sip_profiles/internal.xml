<profile name="internal">
  <settings>
    <param name="debug" value="0"/>
    <param name="sip-trace" value="no"/>

    <param name="sip-port" value="5060"/>
    <param name="dialplan" value="XML"/>
    <param name="context" value="default"/>

    <param name="rfc2833-pt" value="101"/>
    <param name="dtmf-duration" value="2000"/>

    <param name="inbound-codec-prefs" value="$${global_codec_prefs}"/>
    <param name="outbound-codec-prefs" value="$${outbound_codec_prefs}"/>

    <param name="rtp-timer-name" value="soft"/>
    <param name="rtp-ip" value="0.0.0.0"/>
    <param name="sip-ip" value="0.0.0.0"/>

    <!-- Allow SIP registration -->
    <param name="manage-presence" value="true"/>
    <param name="inbound-reg-force-matching-username" value="true"/>
    <param name="auth-calls" value="true"/>
    <param name="apply-inbound-acl" value="any_v4.auto"/>
    <param name="apply-register-acl" value="any_v4.auto"/>

    <!-- NAT traversal -->
    <param name="aggressive-nat-detection" value="true"/>
    <param name="NDLB-received-in-nat-reg-contact" value="true"/>
    <param name="NDLB-force-rport" value="true"/>

    <param name="ext-rtp-ip" value="192.168.1.229"/>
    <param name="ext-sip-ip" value="192.168.1.229"/>
  </settings>
</profile>
